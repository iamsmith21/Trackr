// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  applied
  interview
  offer 
  rejected
  ghosted
}

//the table will be pluralized in postgres -> jobs
model Job {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  company String
  role String
  jobUrl String
  status JobStatus
  notes String
  appliedAt DateTime @default(now())
}

model User {
  id String @id @default(uuid())
  firstname String 
  lastname String
  email String @unique
  password String
  jobs Job[]
}