{
  "manifest_version": 3,
  "name": "Trackr Clipper",
  "version": "1.0",
  "description": "Scrapes and tracks jobs directly to your Trackr dashboard in one click.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "*://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*"
      ],
      "js": ["content.js"]
    }
  ]
}
